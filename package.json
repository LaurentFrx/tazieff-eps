{
    "name": "tazieff-eps",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "predev": "node scripts/check-node.mjs && node scripts/gen-build-info.mjs && node scripts/gen-search-index.mjs",
        "dev": "next dev --webpack -p 3000 -H 0.0.0.0",
        "prebuild": "node scripts/gen-build-info.mjs && node scripts/gen-search-index.mjs",
        "build": "next build --webpack",
        "start": "next start",
        "lint": "eslint",
        "pdf:extract:parametres": "node tools/pdf/extract-images.mjs --pdf \"docs/Parametres volume 1.pdf\" --out \"public/media/apprendre/parametres/_src\" --prefix \"parametres\" && node tools/pdf/to-webp.mjs --in \"public/media/apprendre/parametres/_src\" --out \"public/media/apprendre/parametres\" --prefix \"parametres\"",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "type-check": "tsc --noEmit",
        "db:diff": "supabase db diff --schema public",
        "db:push": "supabase db push",
        "db:pull": "supabase db pull",
        "db:types": "supabase gen types typescript --project-id zefkltkiigxkjcrdesrk --schema public > src/types/database.ts",
        "db:reset": "supabase db reset",
        "db:new-migration": "supabase migration new",
        "db:migration-list": "supabase migration list",
        "db:seed": "tsx supabase/seeds/e2_1_seed_users.ts"
    },
    "dependencies": {
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.5.0",
        "@serwist/next": "^9.5.0",
        "@supabase/supabase-js": "^2.93.1",
        "@use-gesture/react": "^10.3.1",
        "lucide-react": "^0.475.0",
        "next": "16.1.4",
        "next-mdx-remote": "^6.0.0",
        "next-themes": "^0.4.6",
        "qrcode.react": "^4.2.0",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-markdown": "^10.1.0",
        "react-mobile-picker": "^1.2.0",
        "rehype-slug": "^6.0.0",
        "remark-gfm": "^4.0.1",
        "serwist": "^9.5.0",
        "three": "^0.183.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@next/bundle-analyzer": "^16.2.1",
        "@tailwindcss/postcss": "^4",
        "@testing-library/react": "^16.1.0",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/three": "^0.183.1",
        "@vitest/ui": "^4.0.18",
        "deepl-node": "^1.24.0",
        "dotenv": "^17.3.1",
        "eslint": "^9",
        "eslint-config-next": "16.1.4",
        "gray-matter": "^4.0.3",
        "jsdom": "^26.0.0",
        "sharp": "^0.33.5",
        "supabase": "^2.93.0",
        "tailwindcss": "^4",
        "typescript": "^5",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=20.9 <23",
        "npm": ">=10"
    }
}
